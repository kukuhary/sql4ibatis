<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <!-- 1단계: 설정 화면 확장점 정의 -->
   <extension
         point="org.eclipse.ui.preferencePages">
      <page
            class="sql4ibatis.preferences.DatabasePreferencePage"
            id="sql4ibatis.preferences.DatabasePreferencePage"
            name="iBATIS SQL Executor">
      </page>
   </extension>

   <!-- 2단계: 단축키 기능 (Alt+Q) 구현을 위한 커맨드, 핸들러, 바인딩 확장점 정의 -->
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="sql4ibatis.commands.runQuery"
            name="Run iBATIS Query">
      </command>
   </extension>
   
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="sql4ibatis.handlers.RunQueryHandler"
            commandId="sql4ibatis.commands.runQuery">
      </handler>
   </extension>
   
   <extension
         point="org.eclipse.ui.bindings">
      <key
            commandId="sql4ibatis.commands.runQuery"
            contextId="org.eclipse.ui.textEditorScope"
            schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
            sequence="ALT+Q">
      </key>
   </extension>

   <!-- 4단계: 결과 출력 뷰 (View) 확장점 정의 (카테고리 지정) -->
   <extension
         point="org.eclipse.ui.views">
      <category
            id="sql4ibatis"
            name="iBATIS SQL Executor">
      </category>
      <view
            category="sql4ibatis"
            class="sql4ibatis.views.QueryResultView"
            id="sql4ibatis.views.QueryResultView"
            name="SQL Result"
            icon="icons/query_result.png"
            restorable="true">
      </view>
   </extension>

   <!-- 5단계: Ctrl + / 주석 토글 기능 정의 (xml, sqlx 확장자에서만 동작) -->
   <!-- 다양한 에디터(기본 텍스트 에디터, WST/SSE XML 에디터 등)에서 모두 동작하도록 모든 토글 주석 커맨드 ID에 핸들러 매핑 -->
   <extension
         point="org.eclipse.ui.handlers">
      <!-- 1. 기본 텍스트 에디터 주석 커맨드 -->
      <handler
            class="sql4ibatis.handlers.ToggleCommentHandler"
            commandId="org.eclipse.ui.edit.text.toggleComment">
         <activeWhen>
            <with variable="activeEditorInput">
               <adapt type="org.eclipse.core.resources.IFile">
                  <or>
                     <test property="org.eclipse.core.resources.extension" value="xml"/>
                     <test property="org.eclipse.core.resources.extension" value="XML"/>
                     <test property="org.eclipse.core.resources.extension" value="sqlx"/>
                     <test property="org.eclipse.core.resources.extension" value="SQLX"/>
                  </or>
               </adapt>
            </with>
         </activeWhen>
      </handler>
      
      <!-- 2. WST/SSE 구조화 텍스트 에디터(XML 에디터) 주석 커맨드 -->
      <handler
            class="sql4ibatis.handlers.ToggleCommentHandler"
            commandId="org.eclipse.wst.sse.ui.toggle.comment">
         <activeWhen>
            <with variable="activeEditorInput">
               <adapt type="org.eclipse.core.resources.IFile">
                  <or>
                     <test property="org.eclipse.core.resources.extension" value="xml"/>
                     <test property="org.eclipse.core.resources.extension" value="XML"/>
                     <test property="org.eclipse.core.resources.extension" value="sqlx"/>
                     <test property="org.eclipse.core.resources.extension" value="SQLX"/>
                  </or>
               </adapt>
            </with>
         </activeWhen>
      </handler>
      
      <!-- 3. XML 전용 뷰/에디터 주석 커맨드 -->
      <handler
            class="sql4ibatis.handlers.ToggleCommentHandler"
            commandId="org.eclipse.wst.xml.ui.toggle.comment">
         <activeWhen>
            <with variable="activeEditorInput">
               <adapt type="org.eclipse.core.resources.IFile">
                  <or>
                     <test property="org.eclipse.core.resources.extension" value="xml"/>
                     <test property="org.eclipse.core.resources.extension" value="XML"/>
                     <test property="org.eclipse.core.resources.extension" value="sqlx"/>
                     <test property="org.eclipse.core.resources.extension" value="SQLX"/>
                  </or>
               </adapt>
            </with>
         </activeWhen>
      </handler>
   </extension>
</plugin>
